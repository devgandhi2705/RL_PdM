# Byte-compiled / cache
__pycache__/
*.py[cod]

# Virtual environments
venv/
.venv/
env/

# Model checkpoints & scalers (large, regenerable via run_all.py)
*.pth
*.pkl

# Raw and processed dataset (large, regenerable via src/feature_extractor.py)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Logs
*.log

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
